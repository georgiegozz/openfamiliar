{
  "name": "openfamiliar-companion",
  "displayName": "OpenFamiliar Companion",
  "description": "Thin VS Code bridge to local OpenFamiliar Core (no API keys in the editor)",
  "version": "0.1.0",
  "publisher": "openfamiliar",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:openfamiliar.askSelection"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openfamiliar.askSelection",
        "title": "OpenFamiliar: Ask about selection"
      },
      {
        "command": "openfamiliar.explainActive",
        "title": "OpenFamiliar: Explain active file"
      },
      {
        "command": "openfamiliar.reviewDiff",
        "title": "OpenFamiliar: Review Git diff"
      },
      {
        "command": "openfamiliar.addToContext",
        "title": "OpenFamiliar: Add file to context"
      },
      {
        "command": "openfamiliar.startAgent",
        "title": "OpenFamiliar: Start agent task"
      },
      {
        "command": "openfamiliar.showSession",
        "title": "OpenFamiliar: Show session"
      }
    ],
    "configuration": {
      "title": "OpenFamiliar",
      "properties": {
        "openfamiliar.coreEndpoint": {
          "type": "string",
          "default": "http://127.0.0.1:17321",
          "description": "Local OpenFamiliar Core endpoint (loopback only)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "test": "node -e \"console.log('vscode-extension:ok')\""
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^7.0.2"
  }
}
