{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenFamiliar",
  "version": "0.1.0",
  "identifier": "dev.openfamiliar.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "mascot",
        "title": "Perrito Tech",
        "url": "index.html?window=mascot",
        "width": 560,
        "height": 360,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": true,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "settings",
        "title": "OpenFamiliar Settings",
        "url": "index.html?window=settings",
        "width": 760,
        "height": 700,
        "minWidth": 680,
        "minHeight": 560,
        "transparent": false,
        "decorations": true,
        "resizable": true,
        "visible": false,
        "skipTaskbar": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost; script-src 'self'; object-src 'none'; frame-src 'none'; base-uri 'self'; form-action 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "shortDescription": "Windows pixel-art desktop companion for one-shot Codex CLI questions.",
    "longDescription": "OpenFamiliar v0.1 runs Perrito Tech as a transparent Windows desktop companion and sends independent, ephemeral questions through an existing Codex CLI installation.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "wix": {
        "language": "en-US"
      }
    }
  }
}
