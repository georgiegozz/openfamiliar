{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openfamiliar.dev/schema/familiar-v1.json",
  "title": "Familiar Pack Manifest v1",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "engine",
    "author",
    "license",
    "personality",
    "states"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "engine": { "type": "string", "minLength": 1 },
    "author": { "type": "string", "minLength": 1 },
    "license": { "type": "string", "minLength": 1 },
    "homepage": { "type": "string" },
    "personality": { "type": "string" },
    "states": {
      "type": "object",
      "required": [
        "idle",
        "thinking",
        "working",
        "approval",
        "success",
        "error"
      ],
      "additionalProperties": { "type": "string" }
    },
    "spriteSheet": {
      "type": "object",
      "required": ["asset", "frameWidth", "frameHeight", "columns", "rows"],
      "properties": {
        "asset": { "type": "string", "minLength": 1 },
        "frameWidth": { "type": "integer", "minimum": 1 },
        "frameHeight": { "type": "integer", "minimum": 1 },
        "columns": { "type": "integer", "minimum": 1 },
        "rows": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "variants": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "animations": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["frames", "fps", "loop"],
        "properties": {
          "frames": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "integer", "minimum": 0 }
          },
          "fps": { "type": "number", "exclusiveMinimum": 0, "maximum": 12 },
          "loop": { "type": "boolean" },
          "interruptible": { "type": "boolean" },
          "priority": { "type": "integer", "minimum": 0 },
          "fallback": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "assetSources": { "type": "array", "items": { "type": "string" } },
    "aiGenerated": { "type": "boolean" }
  },
  "additionalProperties": true
}
