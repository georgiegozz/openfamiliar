{
  "name": "openfamiliar",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first desktop familiars for coding workspaces",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "dev:desktop": "pnpm --filter @openfamiliar/desktop dev",
    "dev:creator": "pnpm --filter @openfamiliar/creator-studio dev",
    "test": "pnpm -r --if-present run test",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "validate:packs": "cargo run -p familiar-cli -- pack validate mascots/perrito-tech && cargo run -p familiar-cli -- pack validate mascots/blank-template",
    "assets:variants": ".venv\\Scripts\\python.exe scripts/assets/build_mascot_variants.py",
    "assets:validate": ".venv\\Scripts\\python.exe scripts/assets/validate_mascot_sheet.py",
    "assets:test": ".venv\\Scripts\\python.exe -m unittest discover -s scripts/assets/tests -p test_*.py",
    "assets:check": "pnpm assets:validate && pnpm assets:test && .venv\\Scripts\\python.exe scripts/assets/build_mascot_variants.py --check",
    "licenses:audit": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/legal/Export-DependencyLicenses.ps1",
    "licenses:check": "pnpm licenses:audit && git diff --exit-code -- docs/legal/dependency-licenses.json",
    "release:verify": "pwsh -NoProfile -File scripts/release/Test-WindowsArtifacts.ps1",
    "schema:check": "pnpm --filter @openfamiliar/schemas test",
    "ci:js": "pnpm format:check && pnpm typecheck && pnpm test && pnpm assets:check && pnpm validate:packs && pnpm licenses:check"
  },
  "devDependencies": {
    "@types/node": "20.17.30",
    "prettier": "3.9.5",
    "typescript": "5.9.3"
  }
}
