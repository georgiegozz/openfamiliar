# Copy to .env only for local experiments. Never commit .env.
# Prefer OS credential store via the desktop app for real keys.

# Ollama
OPENFAMILIAR_OLLAMA_BASE_URL=http://127.0.0.1:11434

# OpenAI-compatible endpoint (OpenAI, xAI Grok API, local proxies, etc.)
OPENFAMILIAR_OPENAI_BASE_URL=https://api.openai.com/v1
OPENFAMILIAR_OPENAI_API_KEY=

# Gemini (Google AI / Cloud developer key — not browser cookies)
OPENFAMILIAR_GEMINI_API_KEY=
OPENFAMILIAR_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# App
OPENFAMILIAR_LOG_LEVEL=info
OPENFAMILIAR_DATA_DIR=
OPENFAMILIAR_TELEMETRY=0
