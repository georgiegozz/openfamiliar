{
  "rules": [
    {
      "id": "aws-access-key",
      "pattern": "AKIA[0-9A-Z]{16}",
      "severity": "error"
    },
    {
      "id": "generic-api-key",
      "pattern": "(?i)(api[_-]?key|secret|token|password)\\s*[:=]\\s*['\"][^'\"]{12,}['\"]",
      "severity": "error",
      "allowlist": {
        "paths": ["**/.env.example", "**/docs/**", "**/examples/**"]
      }
    }
  ]
}
